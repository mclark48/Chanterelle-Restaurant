@page "/login"
@rendermode @(RenderMode.InteractiveServer)
@using restaurant_project.Services
@inject UserService UserService
@inject NavigationManager NavManager
@inject UserSession UserSession

<PageTitle>Chanterelle's Italian - Login</PageTitle>

@* --- MAIN WRAPPER do not alter -@mclark48 --- *@
<div style="display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 100vh; width: 100vw; background-color: #fdfaf5; position: fixed; top: 0; left: 0; z-index: 1; font-family: 'Inter', sans-serif; overflow-y: auto;">
    
    @* --- nav bar overrite -@mclark48 *@
    <div style="width: 100%; display: flex; justify-content: space-between; align-items: center; padding: 20px 40px; position: absolute; top: 0; left: 0; height: 80px; box-sizing: border-box; background: rgba(253, 250, 245, 0.9); z-index: 999;">
        <div style="flex: 1;">
            <img src="images/logo.png" alt="Logo" style="height: 50px; display: block;">
        </div>
        <div style="flex: 1; text-align: right; white-space: nowrap;">
            <NavLink style="margin-left: 20px; color: #666; text-decoration: none; font-size: 1rem;" href="">Home</NavLink>
            <NavLink style="margin-left: 20px; color: #666; text-decoration: none; font-size: 1rem;" href="contact">Contact us</NavLink>
            <NavLink style="margin-left: 20px; color: #d4af37; text-decoration: none; font-size: 1rem; font-weight: bold;" href="signup">Sign Up</NavLink>
        </div>
    </div>

    @* --- CENTERED CONTENT -@mclark48--- *@
    <div style="display: flex; flex-direction: column; align-items: center; width: 100%; max-width: 450px; padding: 20px;">
        
        <div style="margin-bottom: 25px;">
            <img src="images/logo.png" alt="Chanterelle's" style="max-width: 160px;" />
        </div>

        <div style="background: white; padding: 40px; border-radius: 24px; box-shadow: 0 15px 35px rgba(44, 30, 26, 0.1); width: 100%; text-align: center; border: 1px solid #eee; box-sizing: border-box;">
            <h2 style="color: #2c1e1a; margin-bottom: 10px; font-size: 2rem;">Welcome Back</h2>
            <p style="color: #888; font-size: 0.95rem; margin-bottom: 30px;">Sign in to your account</p>

            <form @onsubmit="HandleLogin" @onsubmit:preventDefault>
                <div style="text-align: left;">
                    <div style="margin-bottom: 18px;">
                        <label style="display: block; font-size: 0.85rem; font-weight: 600; color: #555; margin-bottom: 8px;">Email Address</label>
                        <input type="email" @bind="email" placeholder="michaela@example.com" required 
                               style="width: 100%; padding: 14px; border: 1px solid #ddd; border-radius: 10px; box-sizing: border-box; font-size: 1rem;" />
                    </div>

                    <div style="margin-bottom: 25px;">
                        <label style="display: block; font-size: 0.85rem; font-weight: 600; color: #555; margin-bottom: 8px;">Password</label>
                        <input type="password" @bind="password" placeholder="••••••••" required 
                               style="width: 100%; padding: 14px; border: 1px solid #ddd; border-radius: 10px; box-sizing: border-box; font-size: 1rem;" />
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div style="padding: 12px; border-radius: 10px; margin-bottom: 20px; font-size: 0.9rem; background: #f8d7da; color: #721c24; border: 1px solid #f5c6cb;">
                        @errorMessage
                    </div>
                }

                <button type="submit" style="width: 100%; padding: 16px; background: linear-gradient(135deg, #d4af37 0%, #b8962e 100%); color: white; border: none; border-radius: 12px; font-weight: bold; cursor: pointer; font-size: 1.1rem; box-shadow: 0 4px 12px rgba(212, 175, 55, 0.3);">
                    Sign In
                </button>
            </form>

            <div style="margin-top: 30px;">
                <span style="font-size: 0.9rem; color: #888;">New to Chanterelle's?</span>
                <NavLink href="signup" style="display: block; margin-top: 8px; color: #d4af37; font-weight: bold; text-decoration: none; font-size: 1rem;">Create an account</NavLink>
            </div>
        </div>
    </div>
</div>

@code {
    private string email = "";
    private string password = "";
    private string errorMessage = "";

    private async Task HandleLogin()
    {
        errorMessage = "Verifying...";
        StateHasChanged();

        try
        {
            var user = await UserService.LoginUser(email, password);
            if (user != null)
            {
                UserSession.Login(user);
                NavManager.NavigateTo("/order");
            }
            else
            {
                errorMessage = "Invalid email or password.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
        }
    }
}