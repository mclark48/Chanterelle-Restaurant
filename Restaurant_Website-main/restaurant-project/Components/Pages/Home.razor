@page "/"

<PageTitle>Chanterelle's Italian - Authentic Dining</PageTitle>

<div style="display: flex; flex-direction: column; min-height: 100vh; width: 100%; background-color: #fdfaf5; background-image: url('data:image/svg+xml;utf8,<svg xmlns=%22http://www.w3.org/2000/svg%22 width=%22400%22 height=%22400%22 opacity=%220.03%22><path d=%22M100 100 Q 200 50 300 100 T 500 100%22 fill=%22none%22 stroke=%22%232c1e1a%22 stroke-width=%222%22/></svg>'); position: relative; font-family: 'Inter', sans-serif;">
    
    @* --- new header do NAWT touch -@mclark48 --- *@
    <header style="width: 100%; display: flex; justify-content: space-between; align-items: baseline; padding: 30px 60px; box-sizing: border-box; background: white; border-bottom: 1px solid #eee;">
        <div>
            <h1 style="font-family: 'Playfair Display', serif; font-size: 2.5rem; margin: 0; color: #2c1e1a;">Chanterelle's</h1>
            <p style="font-style: italic; font-size: 0.9rem; margin: 5px 0 0 0; color: #555;">Authentic Italian heritage in every bite.</p>
        </div>
        <nav style="display: flex; align-items: center; gap: 20px;">
            <NavLink style="color: #2c1e1a; text-decoration: none; font-weight: bold; font-size: 1.1rem;" href="" Match="NavLinkMatch.All">Home</NavLink>
            <span style="color: #ddd;">|</span>
            <NavLink style="color: #2c1e1a; text-decoration: none; font-size: 1.1rem;" href="order">Order Now</NavLink>
            <span style="color: #ddd;">|</span>
            <NavLink style="color: #d4af37; text-decoration: none; font-weight: bold; font-size: 1.1rem;" href="login">Login</NavLink>
        </nav>
    </header>

    @* --- MAIN CONTENT AREA -@mclark48 --- *@
    <main style="flex: 1; display: flex; justify-content: center; align-items: center; padding: 40px 20px;">
        
        @* The Central Card -@mclark48 *@
        <div style="background: white; padding: 80px 50px; border-radius: 30px; box-shadow: 0 20px 60px rgba(44, 30, 26, 0.08); max-width: 700px; width: 100%; text-align: center; border: 1px solid rgba(255,255,255,0.5);">
            
            <h2 style="font-family: 'Playfair Display', serif; font-size: 3.5rem; color: #2c1e1a; margin: 0;">A Taste of Tradition</h2>
            
            @* The Gold Divider Line thing @mclark48 *@
            <div style="width: 50px; height: 3px; background: #d4af37; margin: 25px auto;"></div>
            
            <p style="line-height: 2; color: #444; font-size: 1.2rem; margin: 0; max-width: 600px; margin: 0 auto;">
                From the rolling hills of Tuscany to the heart of the city, we bring you recipes 
                passed down through generations. Fresh pasta, hand-picked ingredients, and a 
                passion for the perfect pour. Every dish is a tribute to the simplicity and 
                elegance of Italian cooking.
            </p>

            <div style="margin-top: 40px;">
                <NavLink href="order" style="background: #d4af37; color: white; padding: 15px 40px; text-decoration: none; border-radius: 50px; font-weight: bold; text-transform: uppercase; letter-spacing: 1px; font-size: 0.9rem; box-shadow: 0 8px 20px rgba(212, 175, 55, 0.3);">
                    Explore Menu
                </NavLink>
            </div>
        </div>
    </main>

    @* --- FOOTER -@mclark48--- *@
    <footer style="padding: 20px; text-align: center; color: #bbb; font-size: 0.8rem;">
        &copy; 2026 Chanterelle's Italian Restaurant. All rights reserved.
    </footer>
</div>